{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "redirects": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "app.papertrailacademic.com" }],
      "destination": "/app",
      "permanent": false
    },
    {
      "source": "/dashboard",
      "has": [{ "type": "host", "value": "oral.papertrailacademic.com" }],
      "destination": "https://app.papertrailacademic.com/dashboard",
      "permanent": false
    },
    {
      "source": "/report/:id",
      "has": [{ "type": "host", "value": "oral.papertrailacademic.com" }],
      "destination": "https://app.papertrailacademic.com/report/:id",
      "permanent": false
    }
  ],
  "rewrites": [
    { "source": "/app", "destination": "/app.html" },
    { "source": "/session/:token", "destination": "/session.html" },
    { "source": "/report/:id", "destination": "/report.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=63072000; includeSubDomains"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "no-referrer"
        },
        {
          "key": "Permissions-Policy",
          "value": "microphone=(self), camera=(), geolocation=(), payment=()"
        },
        {
          "key": "Cross-Origin-Opener-Policy",
          "value": "same-origin-allow-popups"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://esm.sh https://cdnjs.cloudflare.com https://apis.google.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' https://papertrailacademic.com https://www.gstatic.com https://ssl.gstatic.com https://drive-thirdparty.googleusercontent.com data: blob:; connect-src 'self' https://ktzrdhiqhidexunucuqp.supabase.co wss://ktzrdhiqhidexunucuqp.supabase.co https://esm.sh https://cdnjs.cloudflare.com https://www.googleapis.com https://content.googleapis.com; media-src 'self' blob: https://ktzrdhiqhidexunucuqp.supabase.co; worker-src 'self' blob:; frame-src https://docs.google.com https://apis.google.com https://content.googleapis.com; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
        }
      ]
    },
    {
      "source": "/app",
      "headers": [
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/app.html",
      "headers": [
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
